# Server
NODE_ENV=development
PORT=8080
# Comma-separated allowed origins (leave empty to allow all in dev)
CORS_ORIGINS=

# Database (Supabase Postgres)
# Use Transaction pooler URL for production (pgbouncer=true), direct URL for migrations
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ESCALATE=claude-opus-4-6
ANTHROPIC_MAX_OUTPUT_TOKENS=1500

# Observability
SENTRY_DSN=
LOG_LEVEL=info
